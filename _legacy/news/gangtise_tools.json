  {
    "type": "function",
    "function": {
      "name": "gts_valuation",
      "description": "钢铁社估值分析。返回单只股票的 PE/PB/PS/PEG/PCF 及历史分位数（3年）。",
      "parameters": {
        "type": "object",
        "properties": {
          "security_code": {
            "type": "string",
            "description": "股票代码，例如 '600519.SH'"
          },
          "start_date": {
            "type": "string",
            "description": "开始日期 YYYY-MM-DD，可选"
          },
          "end_date": {
            "type": "string",
            "description": "结束日期 YYYY-MM-DD，可选"
          }
        },
        "required": ["security_code"]
      },
      "action": {
        "type": "http",
        "method": "POST",
        "url": "http://localhost:8766/invoke",
        "body_template": "{\"tool\": \"gts_valuation\", \"args\": {\"security_code\": \"{{security_code}}\", \"start_date\": \"{{start_date}}\", \"end_date\": \"{{end_date}}\"}}"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "gts_financial",
      "description": "钢铁社财务报表。返回三大报表（利润表/资产负债表/现金流量表），支持年度和季度。",
      "parameters": {
        "type": "object",
        "properties": {
          "security_code": {
            "type": "string",
            "description": "股票代码，例如 '600519.SH'"
          },
          "statement": {
            "type": "string",
            "description": "报表类型",
            "enum": ["income", "balance", "cashflow"],
            "default": "income"
          },
          "period": {
            "type": "string",
            "description": "期间类型",
            "enum": ["annual", "quarterly"],
            "default": "annual"
          },
          "report_type": {
            "type": "string",
            "description": "报告期类型，可选，例如 'Q1'/'Q2'/'Q3'/'Q4'"
          }
        },
        "required": ["security_code"]
      },
      "action": {
        "type": "http",
        "method": "POST",
        "url": "http://localhost:8766/invoke",
        "body_template": "{\"tool\": \"gts_financial\", \"args\": {\"security_code\": \"{{security_code}}\", \"statement\": \"{{statement}}\", \"period\": \"{{period}}\", \"report_type\": \"{{report_type}}\"}}"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "gts_quote",
      "description": "钢铁社日K行情（备用，Tushare 不可用时使用）。返回 OHLCV + 前复权数据。",
      "parameters": {
        "type": "object",
        "properties": {
          "securities": {
            "type": "array",
            "items": {"type": "string"},
            "description": "股票代码列表，例如 ['600519.SH', '000858.SZ']"
          },
          "start_date": {
            "type": "string",
            "description": "开始日期 YYYY-MM-DD"
          },
          "end_date": {
            "type": "string",
            "description": "结束日期 YYYY-MM-DD，默认今天"
          },
          "limit": {
            "type": "integer",
            "description": "每只股票最多返回条数，默认250",
            "default": 250
          }
        },
        "required": ["securities"]
      },
      "action": {
        "type": "http",
        "method": "POST",
        "url": "http://localhost:8766/invoke",
        "body_template": "{\"tool\": \"gts_quote\", \"args\": {\"securities\": {{securities}}, \"start_date\": \"{{start_date}}\", \"end_date\": \"{{end_date}}\", \"limit\": {{limit}}}}"
      }
    }
  }
]
