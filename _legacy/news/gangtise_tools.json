            "description": "关键词"
          },
          "securities": {
            "type": "array",
            "items": {"type": "string"},
            "description": "股票代码列表，可选"
          },
          "start_date": {
            "type": "string",
            "description": "开始日期 YYYY-MM-DD"
          },
          "end_date": {
            "type": "string",
            "description": "结束日期 YYYY-MM-DD"
          },
          "size": {
            "type": "integer",
            "description": "返回数量，默认10",
            "default": 10
          },
          "page": {
            "type": "integer",
            "description": "页码，默认1",
            "default": 1
          }
        },
        "required": []
      },
      "action": {
        "type": "http",
        "method": "POST",
        "url": "http://localhost:8766/invoke",
        "body_template": "{\"tool\": \"gts_summary\", \"args\": {\"keyword\": \"{{keyword}}\", \"securities\": {{securities}}, \"start_date\": \"{{start_date}}\", \"end_date\": \"{{end_date}}\", \"size\": {{size}}, \"page\": {{page}}}}"
      }
    }
  },
